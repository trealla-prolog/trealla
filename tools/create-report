#!/usr/bin/env bash

jq-with-lib() {
    jq -L tools/jq "$@"
}

fatal() {
    echo "[FATAL] $@" >&2
    exit 1
}

INPUT_DIRECTORY=${1:?usage: $0 <build-dir-with-json-logs> [out-dir]}
DOCS_DIR="docs"
REPORTS_DIR="$DOCS_DIR/reports"

shopt -s nullglob
json_files=("${INPUT_DIRECTORY}"/*.gcc.json)
shopt -u nullglob

if ((${#json_files[@]} == 0)); then
    echo "error: no *.gcc.json files found in '${INPUT_DIRECTORY}'" >&2
    exit 1
fi

mkdir -p "$REPORTS_DIR"

build_log="$(mktemp)"
trap 'rm -f "$build_log"' EXIT

jq -s 'map(if type == "array" then . else [.] end) | add' \
    "${json_files[@]}" \
    >"$build_log" || fatal "failed to combine gcc logs"

timestamp="$(date +%Y-%m-%d_%H-%M-%S)"
OUT_DIR="$REPORTS_DIR/$timestamp"
mkdir -p "$OUT_DIR"

NORMALIZED_JSON="$OUT_DIR/normalized.json"
REPORT_MD="$OUT_DIR/report.md"
DIAGNOSTICS_MD="$OUT_DIR/diagnostics.md"

ROOT_DIR="$(pwd)"

jq-with-lib \
    --arg input_dir "$INPUT_DIRECTORY" \
    --arg input_file "$build_log" \
    --arg generated_at "$timestamp" \
    --arg root "$ROOT_DIR" \
    -f tools/jq/normalize.jq \
    "$build_log" >"$NORMALIZED_JSON" || fatal "failed to normalize json"

report_count=$(
  find "$REPORTS_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null \
      | wc -l
)

if [[ -z "${report_count:-}" ]]; then
  id=1
else
  id=$((report_count))
fi

errors="$(jq '([.stats.by_kind[] | select(.kind == "error") | .count] | add) // 0' "$NORMALIZED_JSON")"
warnings="$(jq '([.stats.by_kind[] | select(.kind == "warning") | .count] | add) // 0' "$NORMALIZED_JSON")"
notes="$(jq '([.stats.by_kind[] | select(.kind == "note") | .count] | add) // 0' "$NORMALIZED_JSON")"
total="$(jq '.diagnostics | length' "$NORMALIZED_JSON")"

report_permalink="/reports/$timestamp/report/"
report_document="reports/$timestamp/report.md"
diagnostics_permalink="/reports/$timestamp/diagnostics/"
diagnostics_document="reports/$timestamp/diagnostics.md"
reports_index_permalink="/reports/"
reports_index_document="reports/index.md"
normalized_json_url="/reports/$timestamp/normalized.json"

if [ "$2" = "--preview" ]; then
	{
		echo "## Overview"
		echo
		jq-with-lib -r -f tools/jq/report-overview.jq "$NORMALIZED_JSON" || fatal "failed to create overview section"


		echo "## Top diagnostics"
		echo
		jq-with-lib -r -f tools/jq/report-top-diagnostics-short.jq "$NORMALIZED_JSON" || fatal "failed to create top-diagnostics section"
	} | glow
	exit 0
fi

write_front_matter() {
    local title="$1"
    local permalink="$2"
    local report_type="$3"
    local counterpart_key="$4"
    local counterpart_value="$5"

    cat <<EOF
---
layout: default
title: "$title"
permalink: $permalink
id: $id
type: $report_type
generated_at: "$timestamp"
source_directory: "$INPUT_DIRECTORY"
normalized_json: "$normalized_json_url"
parent_index: "$reports_index_permalink"
$counterpart_key: "$counterpart_value"
counts:
  total: $total
  errors: $errors
  warnings: $warnings
  notes: $notes
---

EOF
}

{
    write_front_matter \
        "Report $id" \
        "$report_permalink" \
        "report" \
        "diagnostics_permalink" \
        "$diagnostics_permalink"

    echo "# Report $id"
    echo
    echo "> Auto-generated. Do not edit manually."
    echo
    echo "- Corresponding diagnostics: [diagnostics.md]({{ '$diagnostics_permalink' | relative_url }})"
    echo "- Reports index: [reports index]({{ '$reports_index_permalink' | relative_url }})"
    echo "- Source directory: \`$INPUT_DIRECTORY\`"
    echo "- Generated at: \`$timestamp\`"
    echo "- Normalized JSON: [normalized.json]({{ '$normalized_json_url' | relative_url }})"
    echo

    echo "## Overview"
    echo
    jq-with-lib -r -f tools/jq/report-overview.jq "$NORMALIZED_JSON" || fatal "failed to create overview section"

    echo
    echo "## Top diagnostics"
    echo
    jq-with-lib -r -f tools/jq/report-top-diagnostics.jq "$NORMALIZED_JSON" || fatal "failed to create top-diagnostics section"

    echo
    echo "## Top files with errors"
    echo
    jq-with-lib -r -f tools/jq/report-top-error-files.jq "$NORMALIZED_JSON" || fatal "failed to create top-files section"

    echo
    echo "## Compat stubs used"
    echo
    jq-with-lib -r -f tools/jq/report-compat-stubs.jq "$NORMALIZED_JSON" || fatal "failed to create compat-stubs section"

    echo
    echo "## First 100 unique errors"
    echo
    jq-with-lib -r -f tools/jq/report-unique-errors.jq "$NORMALIZED_JSON" || fatal "failed to create first-100 section"

} >"$REPORT_MD" || fatal "failed to create md report"

{
    write_front_matter \
        "Diagnostics $id" \
        "$diagnostics_permalink" \
        "diagnostics" \
        "report_page" \
        "$report_permalink"

    echo "# Diagnostics $id"
    echo
    echo "> Auto-generated. Do not edit manually."
    echo
    echo "- Corresponding report: [report.md]({{ '$report_permalink' | relative_url }})"
    echo "- Reports index: [reports index]({{ '$reports_index_permalink' | relative_url }})"
    echo "- Source directory: \`$INPUT_DIRECTORY\`"
    echo "- Generated at: \`$timestamp\`"
    echo "- Normalized JSON: [normalized.json]({{ '$normalized_json_url' | relative_url }})"
    echo

    jq-with-lib -r -f tools/jq/report-diagnostics-by-file.jq "$NORMALIZED_JSON" \
        || fatal "failed to create diagnostics.md"

} >"$DIAGNOSTICS_MD" || fatal "failed to create diagnostics.md"


if command -v prettier >/dev/null 2>&1; then
    prettier -w "$REPORT_MD" "$DIAGNOSTICS_MD"
elif command -v npx >/dev/null 2>&1; then
    npx prettier -w "$REPORT_MD" "$DIAGNOSTICS_MD"
elif command -v bunx >/dev/null 2>&1; then
    bunx prettier -w "$REPORT_MD" "$DIAGNOSTICS_MD"
else
    echo "Unable to format markdown files, can't find prettier/npx/bunx"
fi

LATEST_LINK="$REPORTS_DIR/latest"
ln -sfn "$(realpath --relative-to="$REPORTS_DIR" "$OUT_DIR")" "$LATEST_LINK" \
  || fatal "failed to update latest symlink"

echo "Wrote:"
echo "  $NORMALIZED_JSON"
echo "  $REPORT_MD"
echo "  $DIAGNOSTICS_MD"
echo "  $LATEST_LINK -> $OUT_DIR"
